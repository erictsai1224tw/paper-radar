# Notion（不需要 token！只要告訴 Claude Code 推到哪個 page）
NOTION_PARENT_PAGE_URL=https://www.notion.so/your-workspace/AI-Radar-xxxxxxxxxxxxxxxx

# === Telegram: Paper Notify Bot (radar.py，單向推論文) ===
TELEGRAM_NOTIFY_BOT_TOKEN=xxxxxxxxx:AAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_NOTIFY_CHAT_ID=xxxxxxxxxx

# === Telegram: Q&A Bot (bot.py，互動) ===
TELEGRAM_QA_BOT_TOKEN=yyyyyyyyy:BBByyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# Optional：可調參數（也可寫死在 radar.py）
TOP_N=8
HF_API_LIMIT=30
LOG_LEVEL=INFO

# Summarizer: "claude" (default) 或 "gemini"
# 只影響每篇 paper 的 three-sentence 摘要，push_to_notion 仍走 claude（需要 Notion MCP）
SUMMARIZER=claude

# 追蹤作者/實驗室清單（CSV，大小寫不敏感子字串比對）。命中就在 Telegram 訊息前面加 ⭐
# 例：AUTHOR_WATCHLIST=Karpathy, DeepMind, Yann LeCun
AUTHOR_WATCHLIST=

# 是否在每日推送時附上一段 3 分鐘的繁中語音概覽（edge-tts 免費）
# 設為 true 開啟，預設關閉
VOICE_OVERVIEW=false

# Feedback 重排序門檻：累積到多少則 👍/👎 才開始根據 tag 偏好 rerank fresh papers
# 太少會 noise 太大，20-30 差不多
FEEDBACK_RERANK_MIN_SAMPLES=20

# === Telegram Q&A Bot (bot.py) ===
# 授權可用 bot 的 chat_id，CSV。必填，不設 bot.py 拒絕啟動。
TELEGRAM_AUTHORIZED_CHAT_IDS=

# Bot default backend: claude (default) | gemini
BOT_BACKEND=claude

# 每輪帶入的對話對數（user+assistant = 1 輪）
BOT_HISTORY_TURNS=10

# LLM 呼叫 timeout (秒)
BOT_LLM_TIMEOUT=120
